{
  "crons": [
    {
      "path": "/api/cron/refresh-mv",
      "schedule": "8 0 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://ozkiz-brandboard.vercel.app https://*.vercel.app"
        }
      ]
    }
  ]
}
